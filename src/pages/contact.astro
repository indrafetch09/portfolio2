---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Floor from "../components/Floor.astro";
import TerminalPanel from "../components/TerminalPanel.astro";
import HeadCmd from "../components/HeadCmd";

const { pathname } = Astro.url;
---

<MainLayout
  title="Contact | Harindra Wahyu"
  ,
  description="This is contact page from Indra website">
  <Navbar />
  <Floor />
  <TerminalPanel>
    <HeadCmd pathname={pathname} client:load />
  </TerminalPanel>
</MainLayout>
