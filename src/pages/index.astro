---
import ASCII from "../components/Banner.jsx";
import Navbar from "../components/Navbar.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Floor from "../components/Floor.astro";
import TerminalPanel from "../components/TerminalPanel.astro";
import HeadCmd from "../components/HeadCmd.jsx";

const { pathname } = Astro.url;
---

<MainLayout title="Harindra Wahyu" , description="This is home page">
    <Floor />
    <Navbar />
    <TerminalPanel>
        <HeadCmd pathname={pathname} client:load />
        <div class="body-cmd gap-2">
            <!-- ASCII art -->
            <ASCII />
        </div>
    </TerminalPanel>
</MainLayout>
